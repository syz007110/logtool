[
  {
    "id": "deepseek-chat",
    "label": "DeepSeek Chat",
    "kind": "openai_compatible",
    "requiresApiKey": true,
    "apiKeyEnv": "DEEPSEEK_API_KEY",
    "baseUrl": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "temperature": 0,
    "top_p": 0.1,
    "timeoutMs": 30000,
    "orchestratorJsonOutput": {
      "mode": "openai_json_object"
    },
    "orchestratorMaxTokens": 4096,
    "capabilities": {
      "toolCalls": true,
      "strictTools": { "default": false },
      "toolNamePattern": "^[a-zA-Z0-9_-]{1,64}$",
      "maxTokensField": "max_tokens",
      "sampling": "send",
      "thinking": null,
      "preserveReasoningContent": false
    },
    "orchestrator": {
      "toolChoice": "auto"
    }
  },
  {
    "id": "kimi-k2.6",
    "label": "Kimi K2.6",
    "kind": "openai_compatible",
    "requiresApiKey": true,
    "apiKeyEnv": "MOONSHOT_API_KEY",
    "baseUrl": "https://api.moonshot.cn/v1",
    "model": "kimi-k2.6",
    "timeoutMs": 60000,
    "orchestratorMaxTokens": 16000,
    "capabilities": {
      "toolCalls": true,
      "strictTools": { "default": true },
      "toolNamePattern": "^[a-zA-Z_][a-zA-Z0-9-_]{2,63}$",
      "maxTokensField": "max_completion_tokens",
      "sampling": "omit",
      "thinking": { "type": "enabled" },
      "preserveReasoningContent": true
    },
    "orchestrator": {
      "toolChoice": "auto"
    }
  }
]
