# 数据库配置
DB_HOST=10.129.42.165
DB_PORT=3306
DB_USER=syz007110
DB_PASSWORD=940927syz
DB_NAME=logtool

# JWT 密钥
JWT_SECRET=your_jwt_secret

# 其他配置
PORT=3000

# 队列配置
QUEUE_CONCURRENCY=3

# 多进程集群配置
CLUSTER_ENABLED=true
WORKER_PROCESSES=max
MAX_MEMORY_RESTART=1G
AUTO_RESTART_ENABLED=true
MAX_RESTART_ATTEMPTS=5
RESTART_DELAY=1000
HEARTBEAT_TIMEOUT=30000

# 队列调度配置
QUEUE_MAX_CONCURRENCY=5
QUEUE_SCHEDULER_INTERVAL=100
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000

# PostgreSQL配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=940927syz
POSTGRES_DB=logtool
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false

# Redis缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 缓存功能配置
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_KEYS=1000
SEARCH_CACHE_TTL_SECONDS=180

# 搜索优化配置
SEARCH_MAX_CONCURRENT=5
SEARCH_TIMEOUT_MS=30000
SEARCH_CACHE_ENABLED=true

# 速率限制配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=30000
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# 性能监控配置
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_MONITORING_INTERVAL=60000
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=30000