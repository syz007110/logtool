{
  "registryVersion": "v1",
  "tools": [
    {
      "toolName": "error_code_lookup",
      "displayName": "故障码查询",
      "enabled": true,
      "intentBindings": [
        "error_code_lookup"
      ],
      "description": "查询故障码对应的含义、参数说明、检测逻辑与处理建议。支持完整日志码、类型码或描述性关键词；若存在多条匹配，应请用户结合子系统等线索确认。",
      "llmSummary": {
        "whenToUse": [
          "/searchcode"
        ],
        "requiredSlots": [],
        "anyOfRequired": [
          [
            "errorCode",
            "keywords"
          ]
        ],
        "optionalSlots": [
          "language"
        ],
        "missingSlotQuestions": {
          "errorCode": "请提供需要查询的故障码，例如 0X010A。"
        }
      },
      "inputContract": {
        "type": "object",
        "requiredSlots": [],
        "anyOfRequired": [
          [
            "errorCode",
            "keywords"
          ]
        ],
        "optionalSlots": [
          "language"
        ],
        "defaultable": {
          "language": "zh-CN"
        },
        "contextFillable": [
          "language"
        ],
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "故障码：完整日志码（如 141010A）或类型码（如 0X010A）",
            "pattern": "^(?:0X[0-9A-F]{4}|[1-9A][0-9A-F]{5}[A-E])$"
          },
          "keywords": {
            "type": "string",
            "description": "关键词"
          },
          "language": {
            "type": "string",
            "enum": [
              "zh-CN",
              "en-US"
            ]
          }
        }
      },
      "outputContract": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "data",
          "error"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "empty",
              "failed"
            ]
          },
          "data": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "items",
                  "ambiguous"
                ],
                "properties": {
                  "ambiguous": {
                    "type": "boolean",
                    "description": "items.length > 1 时为 true，需结合自然语言 text 让用户确认子系统或条目"
                  },
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "subsystem",
                        "code",
                        "displayCode",
                        "shortMessage",
                        "userHint",
                        "operation",
                        "params",
                        "detail",
                        "method",
                        "techSolution",
                        "category",
                        "explanation",
                        "prefix",
                        "prefixRaw"
                      ],
                      "properties": {
                        "subsystem": {
                          "type": "string"
                        },
                        "code": {
                          "type": "string"
                        },
                        "displayCode": {
                          "type": "string"
                        },
                        "shortMessage": {
                          "type": "string"
                        },
                        "userHint": {
                          "type": "string"
                        },
                        "operation": {
                          "type": "string"
                        },
                        "params": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "param1",
                            "param2",
                            "param3",
                            "param4"
                          ],
                          "properties": {
                            "param1": {
                              "type": "string"
                            },
                            "param2": {
                              "type": "string"
                            },
                            "param3": {
                              "type": "string"
                            },
                            "param4": {
                              "type": "string"
                            }
                          }
                        },
                        "detail": {
                          "type": "string"
                        },
                        "method": {
                          "type": "string"
                        },
                        "techSolution": {
                          "type": "string"
                        },
                        "category": {
                          "type": "string"
                        },
                        "explanation": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "prefix": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "prefixRaw": {
                          "type": [
                            "string",
                            "null"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "recordId": {
                  "type": "string"
                }
              }
            }
          },
          "error": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "execution": {
        "mode": "sync",
        "handler": "ErrorCodeLookupTool",
        "timeoutMs": 5000,
        "retryable": false
      },
      "security": {
        "riskLevel": "low",
        "requiredPermissions": [
          "error_code:read"
        ],
        "audit": true
      }
    }
  ]
}
