{
  "registryVersion": "v1",
  "tools": [
    {
      "toolName": "error_code_lookup",
      "displayName": "故障码查询",
      "enabled": true,
      "description": "查询故障码对应的含义、参数说明、检测逻辑与处理建议。支持完整日志码、类型码或描述性关键词；若存在多条匹配，应该追问用户故障码是什么或子系统号是什么（故障码首位）。",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "故障码：完整日志码（如 141010A）或类型码（如 0X010A）",
            "pattern": "^(?:0X[0-9A-F]{4}|[1-9A][0-9A-F]{5}[A-E])$"
          },
          "keywords": {
            "type": "string",
            "description": "关键词"
          },
          "language": {
            "type": "string",
            "enum": [
              "zh-CN",
              "en-US"
            ]
          },
          "subsystem": {
            "type": "string",
            "description": "子系统号（单字符），用于在多结果时缩小范围",
            "pattern": "^[1-9A]$"
          }
        },
        "anyOf": [
          {
            "required": [
              "errorCode"
            ]
          },
          {
            "required": [
              "keywords"
            ]
          }
        ]
      },
      "runtime": {
        "defaults": {
          "language": "zh-CN"
        },
        "execution": {
          "mode": "sync",
          "handler": "errorCodeLookupHandler.execute",
          "timeoutMs": 5000,
          "retryable": false
        }
      },
      "security": {
        "riskLevel": "low",
        "requiredPermissions": [
          "error_code:read"
        ],
        "audit": true
      }
    }
  ]
}
