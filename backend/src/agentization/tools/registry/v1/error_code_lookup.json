{
  "registryVersion": "v1",
  "tools": [
    {
      "toolName": "error_code_lookup",
      "displayName": "故障码查询",
      "enabled": true,
      "description": "查询故障码对应的含义、参数说明、检测逻辑与处理建议。支持单个故障码、多个故障码和关键词查询。",
      "descriptionFile": "./descriptions/error_code_lookup.md",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "seriesCode": {
            "type": "string",
            "enum": [
              "SR",
              "SA"
            ],
            "description": "设备系列码。同一故障码在不同系列下释义可能不同，必须指定；用户未说明时先追问，不要默认猜测。"
          },
          "queryType": {
            "type": "string",
            "enum": [
              "single_code",
              "multiple_codes",
              "keyword"
            ],
            "description": "查询方式。single_code 表示单个故障码，multiple_codes 表示多个故障码，keyword 表示关键词查询。"
          },
          "errorCode": {
            "type": "string",
            "description": "单个故障码原始输入。",
            "minLength": 1,
            "maxLength": 64
          },
          "errorCodes": {
            "type": "array",
            "description": "queryType=multiple_codes 时填写，最多 10 个故障码原始输入，执行层会逐项归一化。",
            "minItems": 1,
            "maxItems": 20,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "keywords": {
            "type": "string",
            "description": "queryType=keyword 时填写，最多 100 个字符。",
            "maxLength": 100
          },
          "language": {
            "type": "string",
            "enum": [
              "zh-CN",
              "en-US"
            ]
          },
          "subsystem": {
            "type": "string",
            "description": "子系统号（单字符），用于在多结果时缩小范围；执行层会自动转为大写。",
            "pattern": "^[1-9A]$"
          }
        },
        "required": [
          "seriesCode",
          "queryType"
        ]
      },
      "runtime": {
        "defaults": {
          "language": "zh-CN"
        },
        "execution": {
          "mode": "sync",
          "handler": "errorCodeLookupHandler.execute",
          "timeoutMs": 5000,
          "retryable": false
        }
      },
      "security": {
        "riskLevel": "low",
        "requiredPermissions": [
          "error_code:read"
        ],
        "permissionBypassChannels": [
          "dingtalk"
        ],
        "audit": true
      }
    }
  ]
}
